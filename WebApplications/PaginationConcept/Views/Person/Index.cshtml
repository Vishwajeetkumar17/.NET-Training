@model List<PaginationConcept.Models.Person>

<h2>Person List</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>BusinessEntityID</th>
            <th>First Name</th>
            <th>Last Name</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var person in Model)
        {
            <tr>
                <td>@person.BusinessEntityID</td>
                <td>@person.FirstName</td>
                <td>@person.LastName</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">

    @if (ViewBag.PageNumber > 1)
    {
        <a href="/Person/Index?pageNumber=@(ViewBag.PageNumber - 1)" class="btn btn-primary">
            Previous
        </a>
    }

    <a href="/Person/Index?pageNumber=@(ViewBag.PageNumber + 1)" class="btn btn-primary">
        Next
    </a>

</div>