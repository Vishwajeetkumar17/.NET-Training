@model MVCDemo.Models.CompanyViewModel

<h1>Company Dashboard</h1>

<div class="row">
    <div class="col-md-7">
        <h3>Employees</h3>
        <table class="table table-bordered table-striped">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Dept (Foreign Key)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model.Employees)
                {
                    <tr>
                        <td>@emp.Id</td>
                        <td>@emp.Name</td>
                        <td>@emp.DepartmentName</td>
                    </tr>
                }
            </tbody>
        </table>
        <a asp-action="EmployeeView" class="btn btn-success">Add Employee</a>
    </div>

    <div class="col-md-5">
        <h3>Departments (Master Table)</h3>
        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>ID (Primary Key)</th>
                    <th>Department Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    <tr>
                        <td>@dept.Id</td>
                        <td>@dept.Name</td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="text-muted small">* Employees reference these IDs</p>
    </div>
</div>