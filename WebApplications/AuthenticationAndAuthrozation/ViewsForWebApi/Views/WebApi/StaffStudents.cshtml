@model List<ViewsForWebApi.Models.StudentModel>
@{
    ViewData["Title"] = "Staff Students";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Students</h2>
    <p class="text-muted mb-4"><span class="route-chip">GET</span>/api/Staff/students</p>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Course</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td class="fw-semibold">@student.Name</td>
                        <td>@student.Course</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
