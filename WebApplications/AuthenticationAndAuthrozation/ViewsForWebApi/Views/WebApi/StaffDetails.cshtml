@model ViewsForWebApi.Models.StaffDetailDto
@{
    ViewData["Title"] = "Staff Details";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Staff Details</h2>
    <p class="text-muted mb-4"><span class="route-chip">GET</span>/api/Admin/staff/{id}</p>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="border rounded p-3 bg-light-subtle">
                <small class="text-muted">ID</small>
                <div class="fw-semibold">@Model.Id</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 bg-light-subtle">
                <small class="text-muted">Username</small>
                <div class="fw-semibold">@Model.Username</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 bg-light-subtle">
                <small class="text-muted">Email</small>
                <div class="fw-semibold">@Model.Email</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 bg-light-subtle">
                <small class="text-muted">Role</small>
                <div class="fw-semibold"><span class="badge text-bg-warning">@Model.Role</span></div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 bg-light-subtle">
                <small class="text-muted">Grades Assigned</small>
                <div class="fw-semibold"><span class="badge text-bg-primary">@Model.GradesAssigned</span></div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="border rounded p-3 bg-light-subtle">
                <small class="text-muted">Created At</small>
                <div class="fw-semibold">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
            </div>
        </div>
    </div>

    <a asp-action="AdminStaff" class="btn btn-outline-secondary">Back to Staff</a>
</div>
