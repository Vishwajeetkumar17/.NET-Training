@model List<ViewsForWebApi.Models.CourseModel>
@{
    ViewData["Title"] = "Student Courses";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Courses</h2>
    <p class="text-muted mb-4"><span class="route-chip">GET</span>/api/Student/courses</p>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Credits</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td>@course.Id</td>
                        <td class="fw-semibold">@course.Name</td>
                        <td>@course.Credits</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
