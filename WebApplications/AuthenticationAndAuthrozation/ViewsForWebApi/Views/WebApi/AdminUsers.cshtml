@model List<ViewsForWebApi.Models.AppUserModel>
@{
    ViewData["Title"] = "Admin Users";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Admin Users</h2>
    <p class="text-muted mb-4"><span class="route-chip">GET</span>/api/Admin/users</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Created At</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td class="fw-semibold">@user.Username</td>
                        <td>@user.Email</td>
                        <td><span class="badge text-bg-info">@user.Role</span></td>
                        <td>@user.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</td>
                        <td class="text-end">
                            <form asp-action="DeleteUser" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">DELETE</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
