@model ViewsForWebApi.Models.SignupRequestModel
@{
    ViewData["Title"] = "Signup";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Create Account</h2>
    <p class="text-muted mb-4"><span class="route-chip">POST</span>/api/Auth/signup</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form asp-action="Signup" method="post" class="row g-3">
        <div class="col-md-6">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" type="password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Role" class="form-label"></label>
            <select asp-for="Role" class="form-select">
                <option value="0">Student</option>
                <option value="1">Staff</option>
                <option value="2">Admin</option>
            </select>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">Signup</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
