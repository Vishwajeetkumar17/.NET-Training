@model List<ViewsForWebApi.Models.StudentModel>
@{
    ViewData["Title"] = "Add Grades";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Select Student to Add Grades</h2>
    <p class="text-muted mb-4"><span class="route-chip">POST</span>/api/Staff/grades</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">No students found.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var student in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">@student.Name</h6>
                            <p class="card-text">
                                <small class="text-muted">ID:</small> <span class="badge text-bg-secondary">@student.Id</span>
                            </p>
                            <p class="card-text">
                                <small class="text-muted">Course:</small> @student.Course
                            </p>
                            <a asp-action="AddGradeForm" asp-route-studentId="@student.Id" class="btn btn-primary btn-sm">Add Grade</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <a asp-action="Index" class="btn btn-outline-secondary mt-4">Back</a>
</div>
