@model List<ViewsForWebApi.Models.StudentDetailDto>
@{
    ViewData["Title"] = "Manage Students";
}

<div class="glass-card p-4">
    <h2 class="page-title mb-1">Manage Students</h2>
    <p class="text-muted mb-4"><span class="route-chip">GET</span>/api/Admin/students</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3">
        <a asp-action="CreateStudent" class="btn btn-primary">+ Add New Student</a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">No students found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle border">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Enrollment #</th>
                        <th>Phone</th>
                        <th>Enrolled At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td>@student.Id</td>
                            <td class="fw-semibold">@student.Username</td>
                            <td>@student.Email</td>
                            <td><span class="badge text-bg-info">@student.EnrollmentNumber</span></td>
                            <td>@student.PhoneNumber</td>
                            <td>@student.EnrolledAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="StudentDetails" asp-route-id="@student.Id" class="btn btn-sm btn-outline-primary">View</a>
                                <form asp-action="DeleteStudent" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@student.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <a asp-action="Index" class="btn btn-outline-secondary mt-4">Back</a>
</div>
